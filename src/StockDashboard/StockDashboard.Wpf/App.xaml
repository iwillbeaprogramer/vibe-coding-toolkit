<Application x:Class="StockDashboard.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark theme color palette -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="#FF0F1115"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FF1A1D24"/>
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF22262F"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#FF2E333D"/>
            <SolidColorBrush x:Key="ForegroundBrush" Color="#FFE6E9EF"/>
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#FF8A93A6"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF6C8EF5"/>
            <SolidColorBrush x:Key="UpBrush" Color="#FF22C55E"/>
            <SolidColorBrush x:Key="DownBrush" Color="#FFEF4444"/>

            <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#FF6C8EF5" Offset="0"/>
                <GradientStop Color="#FFB57BE5" Offset="1"/>
            </LinearGradientBrush>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>

            <Style x:Key="LabelText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MutedForegroundBrush}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="ValueText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FF2C313B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CaretBrush" Value="{StaticResource ForegroundBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
