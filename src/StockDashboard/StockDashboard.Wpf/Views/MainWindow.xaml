<Window x:Class="StockDashboard.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Stock Dashboard" Height="780" Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Stock Dashboard"
                       Foreground="{StaticResource HeaderGradientBrush}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="검색한 종목의 상세 시세, 지표, 그리고 일봉 차트를 확인합니다."
                       Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SymbolBox"
                     Text="{Binding SymbolInput, UpdateSourceTrigger=PropertyChanged}"
                     Grid.Column="0" Margin="0,0,8,0"/>
            <ComboBox x:Name="RangeBox"
                      SelectedItem="{Binding SelectedRange}"
                      Grid.Column="1" Width="100" Margin="0,0,8,0"
                      Background="{StaticResource SurfaceAltBrush}"
                      Foreground="{StaticResource ForegroundBrush}">
                <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">1mo</sys:String>
                <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">6mo</sys:String>
                <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">1y</sys:String>
            </ComboBox>
            <Button Grid.Column="2"
                    Content="검색"
                    Command="{Binding SearchCommand}"
                    Background="{StaticResource AccentBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    Foreground="White"
                    Padding="20,8"/>
        </Grid>

        <!-- Status / error / busy -->
        <Border Grid.Row="2"
                Visibility="{Binding ErrorMessage, Converter={x:Static local:NullToVisibilityConverter.Instance}}"
                Background="#33EF4444"
                BorderBrush="{StaticResource DownBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,0,0,12"
                xmlns:local="clr-namespace:StockDashboard.Wpf.Converters">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DownBrush}"/>
        </Border>

        <!-- Body: details panel + chart -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Detail card -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding Stock.Symbol, FallbackValue=종목 정보}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Stock.Name}" Style="{StaticResource LabelText}" Margin="0,2,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Stock.Quote.Price, StringFormat={}{0:N2}}" FontSize="32" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Stock.Currency}" Style="{StaticResource LabelText}" VerticalAlignment="Bottom" Margin="6,0,0,8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{Binding Stock.Quote.Change, StringFormat={}{0:+0.00;-0.00;0.00}}" FontSize="14" Foreground="{StaticResource MutedForegroundBrush}"/>
                            <TextBlock Text="{Binding Stock.Quote.ChangePercent, StringFormat=' ({0:+0.00;-0.00;0.00}%)'}" FontSize="14" Foreground="{StaticResource MutedForegroundBrush}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="전일 종가" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Stock.Quote.PreviousClose, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="시가" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Stock.Quote.Open, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="고가" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Stock.Quote.DayHigh, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="저가" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Stock.Quote.DayLow, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="거래량" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Stock.Quote.Volume, StringFormat={}{0:N0}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="52주 고가" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Stock.Metrics.FiftyTwoWeekHigh, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="52주 저가" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Stock.Metrics.FiftyTwoWeekLow, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="시가총액" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Stock.Metrics.MarketCap, StringFormat={}{0:N0}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="PER" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Stock.Metrics.PeRatio, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="EPS" Style="{StaticResource LabelText}"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Stock.Metrics.Eps, StringFormat={}{0:N2}, TargetNullValue='N/A'}" Style="{StaticResource ValueText}" TextAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="섹터 / 산업" Style="{StaticResource LabelText}" Margin="0,16,0,2"/>
                        <TextBlock Text="{Binding Stock.Profile.Sector, FallbackValue='N/A'}" Style="{StaticResource ValueText}"/>
                        <TextBlock Text="{Binding Stock.Profile.Industry}" Style="{StaticResource LabelText}"/>

                        <TextBlock Text="기업 / 상품 설명" Style="{StaticResource LabelText}" Margin="0,16,0,2"/>
                        <TextBlock Text="{Binding Stock.Profile.Summary, FallbackValue='N/A'}" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Chart -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="가격 차트 (일봉)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <lvc:CartesianChart x:Name="PriceChart" Grid.Row="1"
                                        LegendPosition="Hidden"
                                        TooltipPosition="Top"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer disclaimer -->
        <TextBlock Grid.Row="4"
                   Text="이 데이터는 정보 제공 목적이며 투자 자문이 아닙니다. 데이터는 지연될 수 있습니다."
                   Style="{StaticResource LabelText}"
                   Margin="0,12,0,0"/>
    </Grid>
</Window>
