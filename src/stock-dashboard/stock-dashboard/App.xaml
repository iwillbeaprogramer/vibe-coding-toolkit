<Application x:Class="stock_dashboard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:stock_dashboard"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- 다크 테마 팔레트 -->
        <Color x:Key="ColorBg">#FF0F172A</Color>
        <Color x:Key="ColorBgGradientEnd">#FF1E293B</Color>
        <Color x:Key="ColorCard">#CC1E293B</Color>
        <Color x:Key="ColorCardBorder">#552563EB</Color>
        <Color x:Key="ColorAccent">#FF38BDF8</Color>
        <Color x:Key="ColorAccentSoft">#3338BDF8</Color>
        <Color x:Key="ColorTextPrimary">#FFE2E8F0</Color>
        <Color x:Key="ColorTextSecondary">#FF94A3B8</Color>
        <Color x:Key="ColorPositive">#FF22C55E</Color>
        <Color x:Key="ColorNegative">#FFF43F5E</Color>
        <Color x:Key="ColorWarning">#FFFBBF24</Color>

        <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColorBg}"/>
        <SolidColorBrush x:Key="BrushCard" Color="{StaticResource ColorCard}"/>
        <SolidColorBrush x:Key="BrushCardBorder" Color="{StaticResource ColorCardBorder}"/>
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
        <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
        <SolidColorBrush x:Key="BrushPositive" Color="{StaticResource ColorPositive}"/>
        <SolidColorBrush x:Key="BrushNegative" Color="{StaticResource ColorNegative}"/>
        <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}"/>

        <LinearGradientBrush x:Key="BrushAppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource ColorBg}" Offset="0"/>
            <GradientStop Color="{StaticResource ColorBgGradientEnd}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BrushChartFill" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#9938BDF8" Offset="0"/>
            <GradientStop Color="#0038BDF8" Offset="1"/>
        </LinearGradientBrush>

        <!-- 텍스트 스타일 -->
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="PriceTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 카드 스타일 (글래스모피즘) -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- 검색 텍스트박스 스타일 -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 검색 버튼 스타일 -->
        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="#FF0F172A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF7DD3FC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#552563EB"/>
                                <Setter Property="Foreground" Value="#FF94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
