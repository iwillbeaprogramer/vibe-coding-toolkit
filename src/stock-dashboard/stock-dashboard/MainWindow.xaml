<Window x:Class="stock_dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:stock_dashboard"
        mc:Ignorable="d"
        Title="Stock Dashboard"
        Height="780" Width="1280"
        MinHeight="640" MinWidth="1024"
        Background="{StaticResource BrushAppBackground}"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 검색 바 -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock Text="STOCK DASHBOARD"
                               Foreground="{StaticResource BrushAccent}"
                               FontWeight="Bold" FontSize="12" Opacity="0.85"/>
                    <TextBlock Text="실시간 종목 정보 조회"
                               Style="{StaticResource HeaderTextStyle}"/>
                </StackPanel>
                <TextBox x:Name="SymbolTextBox"
                         Grid.Column="1"
                         Style="{StaticResource SearchTextBoxStyle}"
                         CharacterCasing="Upper"
                         MaxLength="15"
                         VerticalAlignment="Center"
                         KeyDown="OnSymbolTextBoxKeyDown"/>
                <Button x:Name="SearchButton"
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        Style="{StaticResource SearchButtonStyle}"
                        VerticalAlignment="Center"
                        Content="검색"
                        Click="OnSearchButtonClick"/>
            </Grid>
        </Border>

        <!-- 본문: 좌측 요약 + 우측 차트 -->
        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 요약 카드 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock x:Name="SymbolLabel"
                                   Text="—"
                                   Foreground="{StaticResource BrushAccent}"
                                   FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="NameLabel"
                                   Text="종목을 검색하세요"
                                   Style="{StaticResource HeaderTextStyle}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="ExchangeLabel"
                                   Text=""
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <TextBlock x:Name="PriceLabel" Text="—" Style="{StaticResource PriceTextStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="ChangeLabel" Text=""
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBlock x:Name="ChangePercentLabel" Text=""
                                       FontSize="16" FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 상세 지표 그리드 -->
                    <UniformGrid Grid.Row="2" Columns="2" Rows="5" Margin="0,22,0,0">
                        <StackPanel Margin="0,0,8,12">
                            <TextBlock Text="전일 종가" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="PrevCloseLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="시가" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="OpenLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,12">
                            <TextBlock Text="당일 고가" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="HighLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="당일 저가" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="LowLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,12">
                            <TextBlock Text="거래량" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="VolumeLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="평균 거래량" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="AvgVolumeLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,12">
                            <TextBlock Text="시가총액" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="MarketCapLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="통화" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="CurrencyLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,12">
                            <TextBlock Text="52주 최고가" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="FiftyTwoHighLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="52주 최저가" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="FiftyTwoLowLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                        <TextBlock Text="섹터" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="SectorLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                        <TextBlock Text="산업" Style="{StaticResource LabelTextStyle}" Margin="0,8,0,4"/>
                        <TextBlock x:Name="IndustryLabel" Text="—" Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 우측 차트 카드 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="가격 추이" Style="{StaticResource HeaderTextStyle}"/>
                            <TextBlock x:Name="ChartRangeLabel"
                                       Text="범위를 선택하세요"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ComboBox x:Name="RangeComboBox" Width="100" Margin="0,0,8,0"
                                      SelectionChanged="OnRangeChanged">
                                <ComboBoxItem Content="1mo" IsSelected="True"/>
                                <ComboBoxItem Content="3mo"/>
                                <ComboBoxItem Content="6mo"/>
                                <ComboBoxItem Content="1y"/>
                                <ComboBoxItem Content="5y"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,16,0,0"
                            CornerRadius="10"
                            Background="#22000000"
                            BorderBrush="{StaticResource BrushCardBorder}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Grid x:Name="ChartContainer">
                            <Canvas x:Name="ChartCanvas" Background="Transparent"
                                    SizeChanged="OnChartCanvasSizeChanged"/>
                            <TextBlock x:Name="ChartPlaceholderLabel"
                                       Text="검색하여 차트를 표시합니다"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 상태 표시 -->
        <Border Grid.Row="2" Margin="6,6,6,0"
                Background="#221E293B"
                BorderBrush="{StaticResource BrushCardBorder}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel"
                           Grid.Column="0"
                           Text="대기 중"
                           Foreground="{StaticResource BrushTextSecondary}"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                <ProgressBar x:Name="LoadingBar"
                             Grid.Column="1"
                             Width="160" Height="6"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Foreground="{StaticResource BrushAccent}"
                             Background="Transparent"
                             BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
