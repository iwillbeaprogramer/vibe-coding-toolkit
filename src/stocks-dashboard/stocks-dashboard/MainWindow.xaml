<Window x:Class="stocks_dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:stocks_dashboard"
        mc:Ignorable="d"
        Title="주식 정보 검색 및 분석 대시보드 (투자 자문 제외)" Height="720" Width="1180"
        Background="#FF1E1E26" Foreground="#FFEAEAEA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFA0A0B0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF8FB6FF" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF4A6BFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A36" />
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="BorderBrush" Value="#FF4A6BFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SymbolTextBox" Grid.Column="0"
                     KeyDown="SymbolTextBox_KeyDown"
                     ToolTip="미국 상장 주식/ETF 티커를 입력하세요 (예: QLD)" />
            <Button x:Name="SearchButton" Grid.Column="1" Content="검색"
                    Margin="8,0,0,0" Click="SearchButton_Click" />
            <TextBlock Grid.Column="2" Style="{StaticResource LabelText}"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       Text="※ 본 앱은 정보 조회 도구이며 투자 자문이 아닙니다." />
        </Grid>

        <!-- Summary header -->
        <Border Grid.Row="1" Background="#FF2A2A36" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="NameTextBlock" Text="종목을 검색해 주세요"
                               FontSize="20" FontWeight="Bold" />
                    <TextBlock x:Name="SymbolTextBlock" Style="{StaticResource LabelText}"
                               Text="symbol · exchange · currency" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock x:Name="PriceTextBlock" Text="-" FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="ChangeTextBlock" Text="-" FontSize="14"
                               HorizontalAlignment="Right" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: left details / right chart -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: details panel -->
            <Border Grid.Column="0" Background="#FF2A2A36" CornerRadius="6" Padding="14" Margin="0,0,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="시세" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="현재가" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuotePrice" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="전일 종가" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuotePrevClose" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="시가" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuoteOpen" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="고가" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuoteHigh" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="저가" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuoteLow" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelText}" Text="거래량" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuoteVolume" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelText}" Text="평균 거래량" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuoteAvgVolume" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource LabelText}" Text="기준 시각" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="QuoteAsOf" Text="N/A" HorizontalAlignment="Right" />
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="기본 지표" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="시가총액" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="FundMarketCap" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="PER" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="FundPE" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="EPS" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="FundEPS" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="배당수익률" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="FundDividendYield" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="52주 고가" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="Fund52High" Text="N/A" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelText}" Text="52주 저가" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="Fund52Low" Text="N/A" HorizontalAlignment="Right" />
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="개요" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Text="유형  " />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="ProfileAssetType" Text="N/A" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="섹터  " />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="ProfileSector" Text="N/A" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="산업  " />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueText}" x:Name="ProfileIndustry" Text="N/A" />
                        </Grid>
                        <TextBlock x:Name="ProfileDescription"
                                   Style="{StaticResource ValueText}"
                                   FontWeight="Normal" FontSize="12"
                                   Margin="0,8,0,0" Text="설명 정보 없음" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: chart panel -->
            <Border Grid.Column="1" Background="#FF2A2A36" CornerRadius="6" Padding="8" Margin="8,0,0,0">
                <Grid>
                    <ScottPlot:WpfPlot x:Name="PriceChart" />
                    <TextBlock x:Name="ChartPlaceholder" Text="검색하면 차트가 표시됩니다."
                               Foreground="#FF8888A0" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontSize="14" />
                </Grid>
            </Border>
        </Grid>

        <!-- Status / error footer -->
        <Border Grid.Row="3" Background="#FF2A2A36" CornerRadius="6"
                Padding="10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LoadingIndicator" Grid.Column="0"
                           Text="대기 중" Foreground="#FF8FB6FF"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock x:Name="StatusMessage" Grid.Column="1"
                           Text="" TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="4"
              Background="#AA000000" Visibility="Collapsed">
            <Border Background="#FF2A2A36" CornerRadius="8" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="시세 정보를 불러오는 중..."
                           Foreground="#FFEAEAEA" FontSize="16" />
            </Border>
        </Grid>
    </Grid>
</Window>
